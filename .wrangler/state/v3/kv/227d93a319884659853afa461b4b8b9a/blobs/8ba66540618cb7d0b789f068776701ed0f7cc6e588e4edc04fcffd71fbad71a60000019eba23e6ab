<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>销售排队系统</title>
    <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>销售排队系统</h1>
            <div class="user-info">
                <span id="userName">未登录</span>
                <button id="changePwdBtn" onclick="showChangePwd()" style="display:none">修改密码</button>
                <button id="logoutBtn" onclick="doLogout()" style="display:none">退出</button>
            </div>
        </header>

        <nav class="tabs">
            <button class="tab-btn active" onclick="showTab('create')">订单排队</button>
            <button class="tab-btn" onclick="showTab('list')">排队明细</button>
            <button class="tab-btn" onclick="showTab('feedback')">问题反馈</button>
        </nav>

        <div id="createTab" class="tab-content active">
            <form id="orderForm" onsubmit="submitOrder(event)">
                <div class="form-group">
                    <label>型号 *</label>
                    <select id="model" required>
                        <option value="">请选择</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>吨位 *</label>
                    <input type="number" id="tonnage" step="0.1" required>
                </div>
                <div class="form-group">
                    <label>客户 *</label>
                    <input type="text" id="customer" required>
                </div>
                <div class="form-group">
                    <label>期望发货日期 *</label>
                    <input type="date" id="expectedDate" required>
                </div>
                <div class="form-group">
                    <label>可发货日期</label>
                    <input type="text" id="calculatedDate" readonly>
                </div>
                <div class="form-group">
                    <label>输入发货日期排队 *</label>
                    <input type="date" id="queueDate" required>
                </div>
                <div class="form-actions">
                    <button type="submit">提交排队</button>
                    <button type="button" onclick="clearOrderForm()">重置</button>
                </div>
            </form>
        </div>

        <div id="listTab" class="tab-content">
            <div id="adminFilter" class="admin-filter-container"></div>
            <div class="filter-bar">
                <div id="adminFilter" class="admin-filter"></div>
                <select id="filterModel" onchange="filterOrders()">
                    <option value="">全部型号</option>
                </select>
                <input type="text" id="filterCustomer" placeholder="客户筛选..." oninput="filterOrders()">
                <select id="sortSelect" onchange="sortOrders()">
                    <option value="">默认排序</option>
                    <option value="model">按型号排序</option>
                    <option value="queueDate">按排队日期排序</option>
                    <option value="tonnage">按吨位排序</option>
                </select>
            </div>
            <div id="ordersList" class="orders-list"></div>
            <div id="pagination" class="pagination-container"></div>
        </div>

        <div id="feedbackTab" class="tab-content">
            <form id="feedbackForm" onsubmit="submitFeedback(event)">
                <div class="form-group">
                    <label>反馈内容 *</label>
                    <textarea id="feedbackContent" rows="5" required></textarea>
                </div>
                <div class="form-actions">
                    <button type="submit">提交反馈</button>
                </div>
            </form>
        </div>
    </div>

    <div id="authOverlay" class="overlay" style="display:none">
        <div class="auth-box">
            <h2>需要授权访问</h2>
            <select id="authUser">
                <option value="">请选择员工</option>
            </select>
            <input type="password" id="authPassword" placeholder="请输入密码">
            <button onclick="doAuth()">登 录</button>
        </div>
    </div>

    <script src="/static/js/app.js"></script>
</body>
</html>
